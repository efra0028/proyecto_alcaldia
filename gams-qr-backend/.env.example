# Variables de entorno — GAMS QR Backend
# Copia este archivo a .env y completa los valores reales

# ─── Base de datos PostgreSQL ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=TU_PASSWORD_AQUI
DB_NAME=gams_qr

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=CAMBIA_POR_CLAVE_SECRETA_LARGA_Y_SEGURA
JWT_EXPIRES_IN=8h

# ─── App ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001
QR_STORAGE_PATH=public/qr
